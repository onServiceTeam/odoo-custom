<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════
         Case Line (inline) — used inside the case form billing tab
         No standalone views needed; these are embedded.

         Standalone list for debugging / admin only:
         ═══════════════════════════════════════════════════════════════ -->

    <record id="view_case_line_list" model="ir.ui.view">
        <field name="name">ons.case.line.list</field>
        <field name="model">ons.case.line</field>
        <field name="arch" type="xml">
            <list string="Billing Lines" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="product_id"/>
                <field name="description"/>
                <field name="quantity"/>
                <field name="unit_price"/>
                <field name="subtotal"/>
            </list>
        </field>
    </record>

</odoo>
