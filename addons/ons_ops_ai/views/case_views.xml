<odoo>

    <!-- Add AI buttons and fields to case form -->
    <record id="view_case_form_ai" model="ir.ui.view">
        <field name="name">ons.case.form.ai</field>
        <field name="model">ons.case</field>
        <field name="inherit_id" ref="ons_ops_cases.view_case_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_ai_runs" type="object"
                    class="oe_stat_button" icon="fa-robot">
                    <field name="ai_run_count" string="AI Runs" widget="statinfo"/>
                </button>
            </xpath>
            <xpath expr="//header/button[@name='action_reopen']" position="after">
                <button name="action_ai_summarize" type="object"
                    string="AI Summary" class="btn-secondary"/>
                <button name="action_ai_customer_report" type="object"
                    string="Customer Report" class="btn-secondary"/>
            </xpath>
            <xpath expr="//field[@name='summary']" position="after">
                <field name="ai_summary" readonly="1"/>
                <field name="customer_report" readonly="1"/>
            </xpath>
        </field>
    </record>

</odoo>
