<odoo>

    <record id="view_ai_task_list" model="ir.ui.view">
        <field name="name">ons.ai.task.list</field>
        <field name="model">ons.ai.task</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="task_type"/>
                <field name="display_name_custom"/>
                <field name="model_id"/>
                <field name="fallback_model_id"/>
                <field name="temperature"/>
                <field name="max_tokens"/>
                <field name="is_enabled"/>
                <field name="prompt_template_id"/>
            </list>
        </field>
    </record>

    <record id="view_ai_task_form" model="ir.ui.view">
        <field name="name">ons.ai.task.form</field>
        <field name="model">ons.ai.task</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="task_type"/>
                            <field name="display_name_custom"/>
                            <field name="is_enabled"/>
                        </group>
                        <group>
                            <field name="model_id"/>
                            <field name="fallback_model_id"/>
                            <field name="temperature"/>
                            <field name="max_tokens"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                        <field name="prompt_template_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_tasks" model="ir.actions.act_window">
        <field name="name">AI Task Routing</field>
        <field name="res_model">ons.ai.task</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
