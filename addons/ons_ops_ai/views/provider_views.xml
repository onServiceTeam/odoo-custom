<odoo>

    <record id="view_ai_provider_list" model="ir.ui.view">
        <field name="name">ons.ai.provider.list</field>
        <field name="model">ons.ai.provider</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="display_name_custom"/>
                <field name="provider_type"/>
                <field name="api_endpoint"/>
                <field name="is_active"/>
                <field name="health_status"
                    decoration-success="health_status == 'healthy'"
                    decoration-warning="health_status == 'degraded'"
                    decoration-danger="health_status == 'down'" widget="badge"/>
                <field name="last_health_check"/>
            </list>
        </field>
    </record>

    <record id="view_ai_provider_form" model="ir.ui.view">
        <field name="name">ons.ai.provider.form</field>
        <field name="model">ons.ai.provider</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_healthy" type="object"
                        string="Mark Healthy" class="btn-primary"/>
                    <button name="action_mark_down" type="object"
                        string="Mark Down" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="display_name_custom"/>
                            <field name="provider_type"/>
                        </group>
                        <group>
                            <field name="api_endpoint"/>
                            <field name="is_active"/>
                            <field name="health_status"/>
                            <field name="last_health_check"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Models">
                            <field name="model_ids">
                                <list editable="bottom">
                                    <field name="model_id"/>
                                    <field name="display_name_custom"/>
                                    <field name="category"/>
                                    <field name="pricing_tier"/>
                                    <field name="is_available"/>
                                </list>
                            </field>
                        </page>
                        <page string="Configuration">
                            <field name="config_json" widget="text"
                                placeholder="JSON configuration (API keys managed by sidecar)"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_providers" model="ir.actions.act_window">
        <field name="name">AI Providers</field>
        <field name="res_model">ons.ai.provider</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
