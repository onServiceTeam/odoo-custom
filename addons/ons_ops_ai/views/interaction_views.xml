<odoo>

    <!-- Add AI buttons to interaction form -->
    <record id="view_interaction_form_ai" model="ir.ui.view">
        <field name="name">ons.interaction.form.ai</field>
        <field name="model">ons.interaction</field>
        <field name="inherit_id" ref="ons_ops_intake.view_interaction_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/div[@class='oe_title']" position="before">
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_ai_runs" type="object"
                        class="oe_stat_button" icon="fa-robot">
                        <field name="ai_run_count" string="AI Runs" widget="statinfo"/>
                    </button>
                </div>
            </xpath>
            <xpath expr="//header/button[@name='action_classify']" position="after">
                <button name="action_ai_classify" type="object"
                    string="AI Classify" class="btn-secondary"
                    invisible="state not in ('new', 'classified')"/>
                <button name="action_ai_polish" type="object"
                    string="AI Polish" class="btn-secondary"
                    invisible="not issue_description"/>
            </xpath>
        </field>
    </record>

</odoo>
