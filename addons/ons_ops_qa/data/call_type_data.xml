<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- ═══════════════════════════════════════════════════════════════
         QA Call Types — seeded from legacy qa_call_types_v3
         ═══════════════════════════════════════════════════════════════ -->

    <record id="call_type_first_time_intake" model="ons.qa.call.type">
        <field name="key">first_time_intake</field>
        <field name="name">First-Time Intake</field>
        <field name="description">New caller, no prior history. Full intake flow expected.</field>
        <field name="phases">call_control,opening,foundations,session_start,verification,upsell</field>
        <field name="phase_weights_json">{"call_control": 15, "opening": 10, "foundations": 20, "session_start": 15, "verification": 20, "upsell": 20}</field>
        <field name="detection_priority">100</field>
        <field name="is_active" eval="True"/>
    </record>

    <record id="call_type_callback" model="ons.qa.call.type">
        <field name="key">callback</field>
        <field name="name">Callback</field>
        <field name="description">Return call to existing customer/lead.</field>
        <field name="phases">call_control,opening,foundations,session_start,verification</field>
        <field name="phase_weights_json">{"call_control": 15, "opening": 15, "foundations": 20, "session_start": 25, "verification": 25}</field>
        <field name="detection_priority">90</field>
        <field name="is_active" eval="True"/>
    </record>

