<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ Interaction — Tree ═══ -->
    <record id="view_interaction_tree" model="ir.ui.view">
        <field name="name">ons.interaction.tree</field>
        <field name="model">ons.interaction</field>
        <field name="arch" type="xml">
            <list decoration-muted="state == 'completed'"
                  decoration-info="state == 'new'"
                  decoration-warning="state == 'classified'"
                  multi_edit="1">
                <field name="name"/>
                <field name="call_start" widget="datetime"/>
                <field name="interaction_type"/>
                <field name="direction" optional="hide"/>
                <field name="partner_id"/>
                <field name="customer_phone" optional="hide"/>
                <field name="subject" optional="show"/>
                <field name="agent_id" widget="many2one_avatar_user"/>
                <field name="primary_driver_id" optional="show"/>
                <field name="call_status" widget="badge" optional="show"/>
                <field name="repair_status" optional="hide"/>
                <field name="session_path" optional="hide"/>
                <field name="disposition" optional="hide"/>
                <field name="duration_display" string="Duration" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'new'"
                       decoration-warning="state == 'classified'"
                       decoration-success="state == 'completed'"/>
            </list>
        </field>
    </record>

    <!-- ═══ Interaction — Form (guided intake layout matching legacy) ═══ -->
    <record id="view_interaction_form" model="ir.ui.view">
        <field name="name">ons.interaction.form</field>
        <field name="model">ons.interaction</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_classify" string="Classify"
                            type="object" class="btn-primary"
                            invisible="state != 'new'"/>
                    <button name="action_assign" string="Assign"
                            type="object" class="btn-primary"
                            invisible="state not in ('new', 'classified')"/>
                    <button name="action_complete" string="Complete"
                            type="object" class="btn-success"
                            invisible="state == 'completed'"/>
                    <button name="action_resolve_customer" string="Resolve Customer"
                            type="object" class="btn-secondary"
                            invisible="partner_id"/>
                    <button name="action_reset_to_new" string="Reset"
                            type="object" class="btn-link"
                            invisible="state == 'new'"
                            groups="ons_ops_core.group_ops_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,classified,assigned,completed"/>
                </header>
                <sheet>
                    <div class="oe_title mb-3">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- ─── Section 1: Call Story (subject + description prominent) ─── -->
                    <group string="Call Story">
                        <field name="subject" placeholder="Brief subject — what does the customer need?"
                               class="fw-bold"/>
                        <field name="issue_description"
                               placeholder="Detailed description of the issue, steps taken, etc."
                               widget="text"/>
                    </group>

                    <!-- ─── Section 2: Customer (phone auto-lookup, partner link) ─── -->
                    <group>
                        <group string="Customer">
                            <field name="customer_phone" widget="phone"
                                   placeholder="Enter phone to auto-lookup..."/>
                            <field name="partner_id"/>
                            <field name="customer_name" placeholder="Name as stated by caller"/>
                            <field name="customer_email" widget="email"/>
                            <field name="caller_type"/>
                            <field name="customer_type"/>
                        </group>

                        <!-- ─── Section 3: Call Details ─── -->
                        <group string="Call Details">
                            <field name="interaction_type"/>
                            <field name="direction"/>
                            <field name="queue_name"/>
                            <field name="call_status"/>
                            <field name="urgency"/>
                            <field name="disposition"/>
                            <field name="call_start"/>
                            <field name="call_end" invisible="not call_end"/>
                            <field name="duration_display" invisible="not call_duration"/>
                        </group>
                    </group>

                    <!-- ─── Section 4: Session Intent (conditional sub-sections) ─── -->
                    <group string="Session Intent">
                        <group>
                            <field name="session_path" widget="radio"/>
                            <field name="repair_status"/>
                        </group>
                        <group>
                            <!-- Session Now details -->
                            <field name="online_session_started"
                                   invisible="session_path != 'session_now'"/>
                            <field name="session_start_time"
                                   invisible="session_path != 'session_now'"/>
                            <!-- Callback details -->
                            <field name="callback_requested"
                                   invisible="session_path not in ('callback', 'session_scheduled')"/>
                            <field name="callback_time"
                                   invisible="session_path not in ('callback', 'session_scheduled')"/>
                            <field name="callback_timezone"
                                   invisible="session_path not in ('callback', 'session_scheduled')"/>
                        </group>
                    </group>

                    <!-- ─── Onsite Address (only when onsite_queue) ─── -->
                    <group string="Onsite Address"
                           invisible="session_path != 'onsite_queue'">
                        <group>
                            <field name="address_street" placeholder="Street address"/>
                            <field name="address_street2" placeholder="Apt / Suite"/>
                            <field name="address_city" placeholder="City"/>
                        </group>
                        <group>
                            <field name="address_state" placeholder="State"/>
                            <field name="address_zip" placeholder="ZIP code"/>
                        </group>
                    </group>

                    <!-- ─── Section 5: Team ─── -->
                    <group>
                        <group string="Team">
                            <field name="agent_id" widget="many2one_avatar_user"/>
                            <field name="assisting_agent_id" widget="many2one_avatar_user"/>
                            <field name="billing_agent_id" widget="many2one_avatar_user"/>
                        </group>

                        <!-- ─── Section 6: Classification ─── -->
                        <group string="Classification">
                            <field name="primary_driver_id"/>
                            <field name="secondary_driver_ids" widget="many2many_tags"/>
                            <field name="ai_confidence" invisible="not ai_confidence"/>
                        </group>
                    </group>

                    <!-- ─── Notebook: supplementary tabs ─── -->
                    <notebook>
                        <page string="Recording" name="recording"
                              invisible="not has_recording">
                            <group>
                                <field name="has_recording"/>
                                <field name="recording_url" widget="url"/>
                                <field name="talk_duration"/>
                            </group>
                        </page>
                        <page string="Transcript" name="transcript"
                              invisible="not transcript">
                            <group>
                                <field name="transcript_status"/>
                            </group>
                            <field name="transcript" readonly="1"/>
                        </page>
                        <page string="Links" name="links">
                            <group>
                                <field name="lead_id"/>
                            </group>
                        </page>
                        <page string="Identifiers" name="identifiers"
                              groups="ons_ops_core.group_ops_admin">
                            <group>
                                <field name="threecx_cdr_id"/>
                                <field name="legacy_discord_thread_id"/>
                                <field name="legacy_odoo_ticket_id"/>
                                <field name="ai_classification_raw"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══ Interaction — Search ═══ -->
    <record id="view_interaction_search" model="ir.ui.view">
        <field name="name">ons.interaction.search</field>
        <field name="model">ons.interaction</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="customer_phone"/>
                <field name="customer_name"/>
                <field name="partner_id"/>
                <field name="agent_id"/>
                <field name="primary_driver_id"/>
                <separator/>
                <filter name="filter_today" string="Today" date="call_start"/>
                <separator/>
                <filter name="filter_new" string="New"
                        domain="[('state', '=', 'new')]"/>
                <filter name="filter_classified" string="Classified"
                        domain="[('state', '=', 'classified')]"/>
                <filter name="filter_assigned" string="Assigned"
                        domain="[('state', '=', 'assigned')]"/>
                <filter name="filter_completed" string="Completed"
                        domain="[('state', '=', 'completed')]"/>
                <separator/>
                <filter name="filter_phone" string="Phone"
                        domain="[('interaction_type', '=', 'phone')]"/>
                <filter name="filter_inbound" string="Inbound"
                        domain="[('direction', '=', 'inbound')]"/>
                <separator/>
                <filter name="filter_my" string="My Interactions"
                        domain="[('agent_id', '=', uid)]"/>
                <group colspan="16">
                    <filter name="group_state" string="State"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_agent" string="Agent"
                            context="{'group_by': 'agent_id'}"/>
                    <filter name="group_driver" string="Primary Driver"
                            context="{'group_by': 'primary_driver_id'}"/>
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'interaction_type'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by': 'call_start:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══ Interaction — Action ═══ -->
    <record id="action_interaction_list" model="ir.actions.act_window">
        <field name="name">Interactions</field>
        <field name="res_model">ons.interaction</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_interaction_search"/>
        <field name="context">{'search_default_filter_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Log a new interaction
            </p>
            <p>Track every customer contact — phone, email, SMS, or web form.</p>
        </field>
    </record>

    <!-- ═══ Menus under Operations → Intake & CRM ═══ -->
    <menuitem
        id="menu_ops_interactions"
        name="Interactions"
        parent="ons_ops_shell.menu_ops_intake_section"
        action="action_interaction_list"
        sequence="5"
    />

</odoo>
