<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Sequence for ons.interaction -->
    <record id="seq_interaction" model="ir.sequence">
        <field name="name">Interaction Sequence</field>
        <field name="code">ons.interaction</field>
        <field name="prefix">INT-%(y)s%(month)s%(day)s-</field>
        <field name="padding">4</field>
    </record>

    <!-- ═══ Boot &amp; Startup ═══ -->
