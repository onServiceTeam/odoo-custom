<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <!-- Discord-style voice channel indicator: replace avatar with speaker icon -->
    <t t-inherit="mail.DiscussSidebarChannel.main" t-inherit-mode="extension">
        <xpath expr="//div[@name='threadAvatar']" position="attributes">
            <attribute name="t-att-class">{
                'ms-2': !store.discuss.isSidebarCompact,
                'o-voice-channel-avatar': thread.is_voice_channel,
            }</attribute>
        </xpath>
        <!-- Add speaker icon overlay for voice channels -->
        <xpath expr="//div[@name='threadAvatar']/img" position="before">
            <div t-if="thread.is_voice_channel" class="o-voice-channel-icon-wrapper d-flex align-items-center justify-content-center w-100 h-100 position-absolute rounded-2">
                <i class="fa fa-volume-up o-voice-channel-icon"/>
            </div>
        </xpath>
    </t>
</templates>
