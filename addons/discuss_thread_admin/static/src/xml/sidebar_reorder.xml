<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <!-- Add data-channel-id to channel containers for drag-and-drop identification -->
    <t t-inherit="mail.DiscussSidebarChannel" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o-mail-DiscussSidebarChannel-container')]" position="attributes">
            <attribute name="t-att-data-channel-id">thread.id</attribute>
        </xpath>
    </t>

    <!-- Wrap categories in a div so useSortable has a ref target -->
    <t t-inherit="mail.DiscussSidebarCategories" t-inherit-mode="extension">
        <xpath expr="//t[@t-foreach='store.discuss.allCategories']" position="replace">
            <div t-ref="root" class="o-mail-DiscussSidebarCategories-root">
                <t t-foreach="store.discuss.allCategories" t-as="cat" t-key="cat.id">
                    <t t-if="cat.isVisible" t-call="mail.DiscussSidebarCategories.category">
                        <t t-set="category" t-value="cat"/>
                    </t>
                </t>
            </div>
        </xpath>
    </t>

</templates>
