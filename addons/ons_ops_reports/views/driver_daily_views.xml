<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════
         Driver Daily — List View
         ═══════════════════════════════════════════════════════════════ -->
    <record id="view_report_driver_daily_list" model="ir.ui.view">
        <field name="name">ons.report.driver.daily.list</field>
        <field name="model">ons.report.driver.daily</field>
        <field name="arch" type="xml">
            <list string="Driver Daily Performance" create="0" edit="0" delete="0">
                <field name="report_date"/>
                <field name="driver_id"/>
                <field name="driver_category"/>
                <field name="total_interactions" sum="Total"/>
                <field name="cases_created" sum="Total"/>
                <field name="conversion_rate" widget="float"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         Driver Daily — Pivot View
         ═══════════════════════════════════════════════════════════════ -->
    <record id="view_report_driver_daily_pivot" model="ir.ui.view">
        <field name="name">ons.report.driver.daily.pivot</field>
        <field name="model">ons.report.driver.daily</field>
        <field name="arch" type="xml">
            <pivot string="Driver Daily — Pivot">
                <field name="driver_id" type="row"/>
                <field name="report_date" type="col" interval="week"/>
                <field name="total_interactions" type="measure"/>
                <field name="cases_created" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         Driver Daily — Graph View
         ═══════════════════════════════════════════════════════════════ -->
    <record id="view_report_driver_daily_graph" model="ir.ui.view">
        <field name="name">ons.report.driver.daily.graph</field>
        <field name="model">ons.report.driver.daily</field>
        <field name="arch" type="xml">
            <graph string="Driver Daily — Chart" type="bar">
                <field name="driver_id"/>
                <field name="total_interactions" type="measure"/>
                <field name="cases_created" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         Driver Daily — Search View
         ═══════════════════════════════════════════════════════════════ -->
    <record id="view_report_driver_daily_search" model="ir.ui.view">
        <field name="name">ons.report.driver.daily.search</field>
        <field name="model">ons.report.driver.daily</field>
        <field name="arch" type="xml">
            <search string="Driver Daily Reports">
                <field name="driver_id"/>
                <field name="driver_category"/>
                <field name="report_date"/>
                <separator/>
                <filter name="filter_today" string="Today"
                        domain="[('report_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="filter_yesterday" string="Yesterday"
                        domain="[('report_date', '=', (context_today() - datetime.timedelta(days=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_this_week" string="This Week"
                        domain="[('report_date', '>=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_this_month" string="This Month"
                        domain="[('report_date', '>=', context_today().strftime('%Y-%m-01'))]"/>
                <separator/>
                <group>
                    <filter name="group_driver" string="Driver" context="{'group_by': 'driver_id'}"/>
                    <filter name="group_category" string="Category" context="{'group_by': 'driver_category'}"/>
                    <filter name="group_date" string="Date" context="{'group_by': 'report_date'}"/>
                    <filter name="group_week" string="Week" context="{'group_by': 'report_date:week'}"/>
                    <filter name="group_month" string="Month" context="{'group_by': 'report_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         Driver Daily — Action
         ═══════════════════════════════════════════════════════════════ -->
    <record id="action_report_driver_daily" model="ir.actions.act_window">
        <field name="name">Driver Daily Performance</field>
        <field name="res_model">ons.report.driver.daily</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id" ref="view_report_driver_daily_search"/>
        <field name="context">{'search_default_filter_this_month': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No driver report data yet</p>
            <p>Reports are generated daily at 05:00 UTC.</p>
        </field>
    </record>

</odoo>
