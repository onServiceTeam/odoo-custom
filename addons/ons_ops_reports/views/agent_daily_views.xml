<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════
         Agent Daily — List View
         ═══════════════════════════════════════════════════════════════ -->
    <record id="view_report_agent_daily_list" model="ir.ui.view">
        <field name="name">ons.report.agent.daily.list</field>
        <field name="model">ons.report.agent.daily</field>
        <field name="arch" type="xml">
            <list string="Agent Daily Performance" create="0" edit="0" delete="0"
                  decoration-success="qa_avg_score >= 80"
                  decoration-warning="qa_avg_score &gt;= 60 and qa_avg_score &lt; 80"
                  decoration-danger="qa_auto_fail_count > 0">
                <field name="report_date"/>
                <field name="agent_id"/>
                <field name="total_calls"/>
                <field name="answered_calls"/>
                <field name="missed_calls"/>
                <field name="avg_talk_duration"/>
                <field name="cases_created"/>
                <field name="cases_won"/>
                <field name="revenue" sum="Total Revenue"/>
                <field name="qa_eval_count"/>
                <field name="qa_avg_score" widget="float"/>
                <field name="qa_auto_fail_count"/>
                <field name="dispatch_count"/>
                <field name="ai_cost" sum="Total AI Cost"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         Agent Daily — Pivot View
         ═══════════════════════════════════════════════════════════════ -->
    <record id="view_report_agent_daily_pivot" model="ir.ui.view">
        <field name="name">ons.report.agent.daily.pivot</field>
        <field name="model">ons.report.agent.daily</field>
        <field name="arch" type="xml">
            <pivot string="Agent Daily — Pivot">
                <field name="agent_id" type="row"/>
                <field name="report_date" type="col" interval="week"/>
                <field name="total_calls" type="measure"/>
                <field name="revenue" type="measure"/>
                <field name="cases_created" type="measure"/>
                <field name="qa_avg_score" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         Agent Daily — Graph View
         ═══════════════════════════════════════════════════════════════ -->
    <record id="view_report_agent_daily_graph" model="ir.ui.view">
        <field name="name">ons.report.agent.daily.graph</field>
        <field name="model">ons.report.agent.daily</field>
        <field name="arch" type="xml">
            <graph string="Agent Daily — Chart" type="bar">
                <field name="agent_id"/>
                <field name="total_calls" type="measure"/>
                <field name="revenue" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         Agent Daily — Search View
         ═══════════════════════════════════════════════════════════════ -->
    <record id="view_report_agent_daily_search" model="ir.ui.view">
        <field name="name">ons.report.agent.daily.search</field>
        <field name="model">ons.report.agent.daily</field>
        <field name="arch" type="xml">
            <search string="Agent Daily Reports">
                <field name="agent_id"/>
                <field name="report_date"/>
                <separator/>
                <filter name="filter_today" string="Today"
                        domain="[('report_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="filter_yesterday" string="Yesterday"
                        domain="[('report_date', '=', (context_today() - datetime.timedelta(days=1)).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_this_week" string="This Week"
                        domain="[('report_date', '>=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                <filter name="filter_this_month" string="This Month"
                        domain="[('report_date', '>=', context_today().strftime('%Y-%m-01'))]"/>
                <filter name="filter_last_30" string="Last 30 Days"
                        domain="[('report_date', '>=', (context_today() - datetime.timedelta(days=30)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="filter_my" string="My Reports"
                        domain="[('agent_id', '=', uid)]"/>
                <separator/>
                <group>
                    <filter name="group_agent" string="Agent" context="{'group_by': 'agent_id'}"/>
                    <filter name="group_date" string="Date" context="{'group_by': 'report_date'}"/>
                    <filter name="group_week" string="Week" context="{'group_by': 'report_date:week'}"/>
                    <filter name="group_month" string="Month" context="{'group_by': 'report_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════
         Agent Daily — Action
         ═══════════════════════════════════════════════════════════════ -->
    <record id="action_report_agent_daily" model="ir.actions.act_window">
        <field name="name">Agent Daily Performance</field>
        <field name="res_model">ons.report.agent.daily</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id" ref="view_report_agent_daily_search"/>
        <field name="context">{'search_default_filter_last_30': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No report data yet</p>
            <p>Reports are generated daily at 05:00 UTC.</p>
        </field>
    </record>

</odoo>
