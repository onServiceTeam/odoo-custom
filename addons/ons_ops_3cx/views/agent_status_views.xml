<odoo>

    <!-- ═══════════════════════════════════════════════════════════
         Agent Status – List View
         ═══════════════════════════════════════════════════════════ -->
    <record id="view_agent_status_list" model="ir.ui.view">
        <field name="name">ons.agent.status.list</field>
        <field name="model">ons.agent.status</field>
        <field name="arch" type="xml">
            <list string="Agent Status" default_order="agent_name" create="0" edit="0" delete="0">
                <field name="extension"/>
                <field name="agent_name"/>
                <field name="user_id"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'available'"
                    decoration-warning="status in ('away','lunch','dnd')"
                    decoration-danger="status in ('offline','not_registered')"
                    decoration-info="status == 'on_call'"/>
                <field name="reason" optional="show"/>
                <field name="since" widget="datetime"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         Agent Status – Search View
         ═══════════════════════════════════════════════════════════ -->
    <record id="view_agent_status_search" model="ir.ui.view">
        <field name="name">ons.agent.status.search</field>
        <field name="model">ons.agent.status</field>
        <field name="arch" type="xml">
            <search string="Agent Status">
                <field name="agent_name"/>
                <field name="user_id"/>
                <field name="extension"/>
                <separator/>
                <filter name="available" string="Available" domain="[('status','=','available')]"/>
                <filter name="on_call" string="On Call" domain="[('status','=','on_call')]"/>
                <filter name="offline" string="Offline" domain="[('status','in',['offline','not_registered'])]"/>
                <group>
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         Agent Status – Action
         ═══════════════════════════════════════════════════════════ -->
    <record id="action_agent_status" model="ir.actions.act_window">
        <field name="name">Agent Status</field>
        <field name="res_model">ons.agent.status</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_agent_status_search"/>
    </record>

</odoo>
