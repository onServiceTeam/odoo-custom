<odoo>

    <!-- ═══════════════════════════════════════════════════════════
         User Extension – List View (inline-editable)
         ═══════════════════════════════════════════════════════════ -->
    <record id="view_user_extension_list" model="ir.ui.view">
        <field name="name">ons.user.extension.list</field>
        <field name="model">ons.user.extension</field>
        <field name="arch" type="xml">
            <list string="Extensions" editable="bottom">
                <field name="extension"/>
                <field name="user_id"/>
                <field name="is_active" widget="boolean_toggle"/>
                <field name="notes" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         User Extension – Form View
         ═══════════════════════════════════════════════════════════ -->
    <record id="view_user_extension_form" model="ir.ui.view">
        <field name="name">ons.user.extension.form</field>
        <field name="model">ons.user.extension</field>
        <field name="arch" type="xml">
            <form string="Extension Mapping">
                <sheet>
                    <group>
                        <group>
                            <field name="extension"/>
                            <field name="user_id"/>
                            <field name="is_active"/>
                        </group>
                        <group>
                            <field name="notes"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         User Extension – Search View
         ═══════════════════════════════════════════════════════════ -->
    <record id="view_user_extension_search" model="ir.ui.view">
        <field name="name">ons.user.extension.search</field>
        <field name="model">ons.user.extension</field>
        <field name="arch" type="xml">
            <search string="Extensions">
                <field name="extension"/>
                <field name="user_id"/>
                <separator/>
                <filter name="active_only" string="Active" domain="[('is_active','=',True)]"/>
                <filter name="inactive" string="Inactive" domain="[('is_active','=',False)]"/>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         User Extension – Action
         ═══════════════════════════════════════════════════════════ -->
    <record id="action_user_extension" model="ir.actions.act_window">
        <field name="name">Extensions</field>
        <field name="res_model">ons.user.extension</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_user_extension_search"/>
        <field name="context">{'search_default_active_only': 1}</field>
    </record>

</odoo>
