<odoo>
    <record id="view_checklist_config_list" model="ir.ui.view">
        <field name="name">ons.dispatch.checklist.config.list</field>
        <field name="model">ons.dispatch.checklist.config</field>
        <field name="arch" type="xml">
            <list string="Checklist Config" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="is_required" widget="boolean_toggle"/>
                <field name="is_active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_checklist_config" model="ir.actions.act_window">
        <field name="name">Checklist Config</field>
        <field name="res_model">ons.dispatch.checklist.config</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
