<odoo noupdate="1">
    <record id="status_draft" model="ons.dispatch.status">
        <field name="name">Draft</field>
        <field name="code">draft</field>
        <field name="sequence">10</field>
        <field name="color">0</field>
    </record>
    <record id="status_pending_approval" model="ons.dispatch.status">
        <field name="name">Pending Approval</field>
        <field name="code">pending_approval</field>
        <field name="sequence">20</field>
        <field name="color">3</field>
    </record>
    <record id="status_sent" model="ons.dispatch.status">
        <field name="name">Sent</field>
        <field name="code">sent</field>
        <field name="sequence">30</field>
        <field name="color">4</field>
    </record>
    <record id="status_has_applicants" model="ons.dispatch.status">
        <field name="name">Has Applicants</field>
        <field name="code">has_applicants</field>
        <field name="sequence">40</field>
        <field name="color">2</field>
    </record>
    <record id="status_assigned" model="ons.dispatch.status">
        <field name="name">Assigned</field>
        <field name="code">assigned</field>
        <field name="sequence">50</field>
        <field name="color">10</field>
    </record>
    <record id="status_confirmed" model="ons.dispatch.status">
        <field name="name">Confirmed</field>
        <field name="code">confirmed</field>
        <field name="sequence">60</field>
        <field name="color">10</field>
    </record>
    <record id="status_in_progress" model="ons.dispatch.status">
        <field name="name">In Progress</field>
        <field name="code">in_progress</field>
        <field name="sequence">70</field>
        <field name="color">1</field>
    </record>
    <record id="status_completed" model="ons.dispatch.status">
        <field name="name">Completed</field>
        <field name="code">completed</field>
        <field name="sequence">80</field>
        <field name="is_terminal" eval="True"/>
        <field name="color">10</field>
    </record>
    <record id="status_cancelled" model="ons.dispatch.status">
        <field name="name">Cancelled</field>
        <field name="code">cancelled</field>
        <field name="sequence">90</field>
        <field name="is_terminal" eval="True"/>
        <field name="color">1</field>
    </record>
    <record id="status_voided" model="ons.dispatch.status">
        <field name="name">Voided</field>
        <field name="code">voided</field>
        <field name="sequence">100</field>
        <field name="is_terminal" eval="True"/>
        <field name="color">0</field>
    </record>
</odoo>
