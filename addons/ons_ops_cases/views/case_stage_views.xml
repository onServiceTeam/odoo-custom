<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ Stage List (admin config) ═══ -->
    <record id="view_case_stage_list" model="ir.ui.view">
        <field name="name">ons.case.stage.list</field>
        <field name="model">ons.case.stage</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="is_closed"/>
                <field name="is_won"/>
                <field name="fold"/>
            </list>
        </field>
    </record>

    <record id="action_case_stage_config" model="ir.actions.act_window">
        <field name="name">Case Stages</field>
        <field name="res_model">ons.case.stage</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
