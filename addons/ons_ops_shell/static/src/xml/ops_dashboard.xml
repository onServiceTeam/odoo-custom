<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="ons_ops_shell.OpsDashboard">
        <div class="o_action o_ops_dashboard">

            <!-- ── Header ─────────────────────────────────────── -->
            <div class="o_ops_dashboard_header mb-4">
                <div>
                    <h1 class="o_ops_title mb-1">Operations Center</h1>
                    <p class="o_ops_subtitle mb-0">
                        Welcome back, <t t-esc="state.userName"/>
                    </p>
                </div>
                <div class="o_ops_header_right" t-if="state.etTime">
                    <div class="o_ops_clock">
                        <div class="o_ops_clock_label">Eastern</div>
                        <div class="o_ops_clock_time"><t t-esc="state.etTime"/></div>
                    </div>
                </div>
            </div>

            <!-- ── Status Row ─────────────────────────────────── -->
            <div class="o_ops_status_row" t-if="state.loaded">
                <div class="o_ops_status_item">
                    <span class="o_ops_status_dot online"/>
                    <span class="o_ops_status_count"><t t-esc="state.todayInteractions"/></span>
                    <span>calls today</span>
                </div>
                <div class="o_ops_status_item" t-if="state.staleCases > 0"
                     role="button" t-on-click="openNeedsAttention"
                     style="cursor:pointer; border-color: #F97316;">
                    <span class="o_ops_status_dot busy"/>
                    <span class="o_ops_status_count"><t t-esc="state.staleCases"/></span>
                    <span>stale cases</span>
                </div>
                <div class="o_ops_status_item" t-if="state.needsAttention > 0"
                     role="button" t-on-click="openNeedsAttention"
                     style="cursor:pointer; border-color: #DC2626;">
                    <i class="fa fa-exclamation-triangle text-danger me-1"/>
                    <span class="o_ops_status_count"><t t-esc="state.needsAttention"/></span>
                    <span>need attention</span>
                </div>
            </div>

            <!-- ── KPI Cards ──────────────────────────────────── -->
            <div class="row g-3 mb-4">

                <div class="col-sm-6 col-lg-3">
                    <div class="card o_ops_kpi_card h-100"
                         role="button" tabindex="0"
                         t-on-click="openInteractions">
                        <div class="card-body text-center py-4">
                            <div class="o_ops_kpi_icon bg-primary-light mx-auto">
                                <i class="fa fa-phone fa-fw text-primary"/>
                            </div>
                            <div class="o_ops_kpi_value">
                                <t t-esc="state.openInteractions"/>
                            </div>
                            <div class="o_ops_kpi_label">Active Interactions</div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-lg-3">
                    <div class="card o_ops_kpi_card h-100"
                         role="button" tabindex="0"
                         t-on-click="openCases">
                        <div class="card-body text-center py-4">
                            <div class="o_ops_kpi_icon bg-success-light mx-auto">
                                <i class="fa fa-folder-open fa-fw text-success"/>
                            </div>
                            <div class="o_ops_kpi_value">
                                <t t-esc="state.openCases"/>
                            </div>
                            <div class="o_ops_kpi_label">Open Cases</div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-lg-3">
                    <div class="card o_ops_kpi_card h-100"
                         role="button" tabindex="0"
                         t-on-click="openCallbacks">
                        <div class="card-body text-center py-4">
                            <div class="o_ops_kpi_icon bg-warning-light mx-auto">
                                <i class="fa fa-clock-o fa-fw text-warning"/>
                            </div>
                            <div class="o_ops_kpi_value">
                                <t t-esc="state.callbacksPending"/>
                            </div>
                            <div class="o_ops_kpi_label">Pending Callbacks</div>
                        </div>
                    </div>
                </div>

                <div class="col-sm-6 col-lg-3">
                    <div class="card o_ops_kpi_card h-100"
                         role="button" tabindex="0"
                         t-on-click="openActivities">
                        <div class="card-body text-center py-4">
                            <div class="o_ops_kpi_icon bg-danger-light mx-auto">
                                <i class="fa fa-tasks fa-fw text-danger"/>
                            </div>
                            <div class="o_ops_kpi_value">
                                <t t-esc="state.activityCount"/>
                            </div>
                            <div class="o_ops_kpi_label">My Activities</div>
                        </div>
                    </div>
                </div>

            </div>

            <!-- ── Quick Actions ──────────────────────────────── -->
            <div class="o_ops_quick_actions mb-4">
                <h3 class="o_ops_section_title">Quick Actions</h3>
                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-primary"
                            t-on-click="newInteraction">
                        <i class="fa fa-plus me-1"/>
                        New Intake
                    </button>
                    <button class="btn btn-outline-primary"
                            t-on-click="openCases">
                        <i class="fa fa-folder-open me-1"/>
                        Cases
                    </button>
                    <button class="btn btn-outline-primary"
                            t-on-click="openCustomers">
                        <i class="fa fa-users me-1"/>
                        Customers
                    </button>
                    <button class="btn btn-outline-primary"
                            t-on-click="openPipeline">
                        <i class="fa fa-filter me-1"/>
                        Pipeline
                    </button>
                    <button class="btn btn-outline-primary"
                            t-on-click="openDiscuss">
                        <i class="fa fa-comments me-1"/>
                        Discuss
                    </button>
                </div>
            </div>

            <!-- ── Secondary KPI row ──────────────────────────── -->
            <div class="row g-3 mb-4">
                <div class="col-sm-6 col-lg-4">
                    <div class="card o_ops_kpi_card h-100"
                         role="button" tabindex="0"
                         t-on-click="openCustomers">
                        <div class="card-body d-flex align-items-center py-3 px-4">
                            <i class="fa fa-users fa-2x text-primary me-3"/>
                            <div>
                                <div class="o_ops_kpi_value" style="font-size:22px;">
                                    <t t-esc="state.customerCount"/>
                                </div>
                                <div class="o_ops_kpi_label">Total Customers</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-4">
                    <div class="card o_ops_kpi_card h-100"
                         role="button" tabindex="0"
                         t-on-click="openInteractions">
                        <div class="card-body d-flex align-items-center py-3 px-4">
                            <i class="fa fa-phone fa-2x text-success me-3"/>
                            <div>
                                <div class="o_ops_kpi_value" style="font-size:22px;">
                                    <t t-esc="state.todayInteractions"/>
                                </div>
                                <div class="o_ops_kpi_label">Today's Interactions</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-lg-4" t-if="state.needsAttention > 0">
                    <div class="card o_ops_kpi_card h-100"
                         role="button" tabindex="0"
                         t-on-click="openNeedsAttention"
                         style="border-color: #DC2626;">
                        <div class="card-body d-flex align-items-center py-3 px-4">
                            <i class="fa fa-exclamation-triangle fa-2x text-danger me-3"/>
                            <div>
                                <div class="o_ops_kpi_value" style="font-size:22px;">
                                    <t t-esc="state.needsAttention"/>
                                </div>
                                <div class="o_ops_kpi_label">Needs Attention</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </t>

</templates>
                        Discuss
                    </button>
                    <button class="btn btn-outline-primary"
                            t-on-click="openActivities">
                        <i class="fa fa-clock-o me-1"/>
                        My Activities
                    </button>
                </div>
            </div>

            <!-- ── Info Card ──────────────────────────────────── -->
            <div class="card border-0 bg-100">
                <div class="card-body">
                    <h5 class="card-title mb-2">
                        <i class="fa fa-info-circle me-1 text-primary"/>
                        Getting Started
                    </h5>
                    <p class="card-text text-muted mb-0">
                        This is your Operations Center. As new modules are
                        installed (Intake, Cases, Dispatch, QA, Reports),
                        additional sections and live metrics will appear
                        here automatically. Use the menu on the left to
                        navigate between sections.
                    </p>
                </div>
            </div>

        </div>
    </t>

</templates>
