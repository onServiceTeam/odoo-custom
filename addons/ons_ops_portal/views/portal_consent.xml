<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════
         Consent preferences page
         ═══════════════════════════════════════════════════════════ -->
    <template id="portal_my_consent" name="Communication Preferences">
        <t t-call="portal.portal_layout">

            <h3 class="mt-3 mb-3">Communication Preferences</h3>

            <t t-if="not consents">
                <p class="alert alert-info">
                    No communication preferences are on file.
                    Contact us to set up your notification preferences.
                </p>
            </t>

            <t t-if="consents">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Channel</th>
                                <th>Category</th>
                                <th>Status</th>
                                <th>Since</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="consents" t-as="c">
                                <tr>
                                    <td>
                                        <span t-if="c.channel == 'email'" class="badge text-bg-primary">Email</span>
                                        <span t-elif="c.channel == 'sms'" class="badge text-bg-info">SMS</span>
                                        <span t-else="" class="badge text-bg-secondary">
                                            <t t-out="c.channel"/>
                                        </span>
                                    </td>
                                    <td><t t-out="dict(c._fields['scope'].selection).get(c.scope, c.scope)"/></td>
                                    <td>
                                        <span t-if="c.status in ('opted_in', 'double_opted_in')"
                                              class="badge text-bg-success">Opted In</span>
                                        <span t-elif="c.status == 'pending'"
                                              class="badge text-bg-warning">Pending</span>
                                        <span t-elif="c.status in ('opted_out', 'revoked')"
                                              class="badge text-bg-danger">Opted Out</span>
                                    </td>
                                    <td>
                                        <span t-if="c.opted_in_at" t-field="c.opted_in_at"
                                              t-options='{"widget": "date"}'/>
                                        <span t-elif="c.opted_out_at" t-field="c.opted_out_at"
                                              t-options='{"widget": "date"}'/>
                                    </td>
                                    <td class="text-center">
                                        <t t-if="c.status in ('opted_in', 'double_opted_in')">
                                            <form method="POST" action="/my/consent/toggle"
                                                  class="d-inline">
                                                <input type="hidden" name="csrf_token"
                                                       t-att-value="request.csrf_token()"/>
                                                <input type="hidden" name="consent_id"
                                                       t-att-value="c.id"/>
                                                <input type="hidden" name="action"
                                                       value="opt_out"/>
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger">
                                                    Opt Out
                                                </button>
                                            </form>
                                        </t>
                                        <t t-if="c.status in ('pending',)">
                                            <form method="POST" action="/my/consent/toggle"
                                                  class="d-inline">
                                                <input type="hidden" name="csrf_token"
                                                       t-att-value="request.csrf_token()"/>
                                                <input type="hidden" name="consent_id"
                                                       t-att-value="c.id"/>
                                                <input type="hidden" name="action"
                                                       value="opt_in"/>
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-success">
                                                    Opt In
                                                </button>
                                            </form>
                                        </t>
                                        <t t-if="c.status in ('opted_out', 'revoked')">
                                            <span class="text-muted small">Contact us to re-consent</span>
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>

            <div class="mt-3">
                <a href="/my" class="btn btn-secondary btn-sm">← Back to Dashboard</a>
            </div>

        </t>
    </template>

</odoo>
