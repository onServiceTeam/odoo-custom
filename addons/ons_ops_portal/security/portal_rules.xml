<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Case: portal user sees own partner's cases ───────── -->
    <record id="rule_portal_case_own" model="ir.rule">
        <field name="name">Portal: own cases</field>
        <field name="model_id" ref="ons_ops_cases.model_ons_case"/>
        <field name="domain_force">
            [('partner_id', 'child_of', [user.commercial_partner_id.id])]
        </field>
        <field name="groups" eval="[
            Command.link(ref('base.group_portal')),
        ]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ─── Case Line: indirect via case partner ─────────────── -->
    <record id="rule_portal_case_line_own" model="ir.rule">
