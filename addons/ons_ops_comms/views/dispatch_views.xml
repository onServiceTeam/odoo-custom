<odoo>

    <!-- Dispatch form — add SMS/Email thread smart buttons -->
    <record id="view_dispatch_form_comms" model="ir.ui.view">
        <field name="name">ons.dispatch.form.comms</field>
        <field name="model">ons.dispatch</field>
        <field name="inherit_id" ref="ons_ops_dispatch.view_dispatch_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_sms_threads" type="object"
                    class="oe_stat_button" icon="fa-comment"
                    invisible="sms_thread_count == 0">
                    <field name="sms_thread_count" string="SMS" widget="statinfo"/>
                </button>
                <button name="action_view_email_threads" type="object"
                    class="oe_stat_button" icon="fa-envelope"
                    invisible="email_thread_count == 0">
                    <field name="email_thread_count" string="Emails" widget="statinfo"/>
                </button>
            </div>
        </field>
    </record>

</odoo>
