<odoo>

    <record id="view_notification_log_list" model="ir.ui.view">
        <field name="name">ons.notification.log.list</field>
        <field name="model">ons.notification.log</field>
        <field name="arch" type="xml">
            <list string="Notification Log" create="0" edit="0"
                  decoration-danger="status == 'failed'"
                  decoration-muted="status == 'queued'">
                <field name="create_date" string="When"/>
                <field name="event_type"/>
                <field name="channel" widget="badge"/>
                <field name="status" widget="badge"
                    decoration-success="status == 'delivered'"
                    decoration-info="status == 'sent'"
                    decoration-warning="status == 'queued'"
                    decoration-danger="status == 'failed'"/>
                <field name="sent_to"/>
                <field name="rule_id"/>
                <field name="res_model" optional="show"/>
                <field name="res_id" optional="show"/>
                <field name="error_message" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_notification_log_search" model="ir.ui.view">
        <field name="name">ons.notification.log.search</field>
        <field name="model">ons.notification.log</field>
        <field name="arch" type="xml">
            <search string="Notification Log">
                <field name="event_type"/>
                <field name="sent_to"/>
                <field name="rule_id"/>
                <separator/>
                <filter name="failed" string="Failed" domain="[('status', '=', 'failed')]"/>
                <filter name="queued" string="Queued" domain="[('status', '=', 'queued')]"/>
                <filter name="sms" string="SMS" domain="[('channel', '=', 'sms')]"/>
                <filter name="email" string="Email" domain="[('channel', '=', 'email')]"/>
                <filter name="chatter" string="Chatter" domain="[('channel', '=', 'chatter')]"/>
                <filter name="discuss" string="Discuss" domain="[('channel', '=', 'discuss')]"/>
                <group>
                    <filter name="group_channel" string="Channel" context="{'group_by': 'channel'}"/>
                    <filter name="group_event" string="Event" context="{'group_by': 'event_type'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_notification_log" model="ir.actions.act_window">
        <field name="name">Notification Log</field>
        <field name="res_model">ons.notification.log</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_notification_log_search"/>
    </record>

</odoo>
