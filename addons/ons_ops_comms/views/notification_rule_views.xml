<odoo>

    <!-- ═══════════════════════════════════════════════════════════
         Notification Rule — List
         ═══════════════════════════════════════════════════════════ -->
    <record id="view_notification_rule_list" model="ir.ui.view">
        <field name="name">ons.notification.rule.list</field>
        <field name="model">ons.notification.rule</field>
        <field name="arch" type="xml">
            <list string="Notification Rules" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="event_type"/>
                <field name="notify_customer_sms" widget="boolean_toggle"/>
                <field name="notify_customer_email" widget="boolean_toggle"/>
                <field name="notify_internal_chatter" widget="boolean_toggle"/>
                <field name="notify_internal_discuss" widget="boolean_toggle"/>
                <field name="is_active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         Notification Rule — Form
         ═══════════════════════════════════════════════════════════ -->
    <record id="view_notification_rule_form" model="ir.ui.view">
        <field name="name">ons.notification.rule.form</field>
        <field name="model">ons.notification.rule</field>
        <field name="arch" type="xml">
            <form string="Notification Rule">
                <sheet>
                    <group>
                        <group string="Rule">
                            <field name="name"/>
                            <field name="code"/>
                            <field name="event_type"/>
                            <field name="target_model"/>
                            <field name="is_active"/>
                            <field name="sequence"/>
                        </group>
                        <group string="Channels">
                            <field name="notify_customer_sms"/>
                            <field name="notify_customer_email"/>
                            <field name="notify_internal_chatter"/>
                            <field name="notify_internal_discuss"/>
                        </group>
                    </group>
                    <group>
                        <group string="SMS/Email Templates">
                            <field name="sms_template_id" invisible="not notify_customer_sms"/>
                            <field name="email_template_id" invisible="not notify_customer_email"/>
                        </group>
                        <group string="Internal Templates">
                            <field name="chatter_body" invisible="not notify_internal_chatter"/>
                            <field name="discuss_channel_id" invisible="not notify_internal_discuss"/>
                            <field name="discuss_body" invisible="not notify_internal_discuss"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════
         Notification Rule — Action
         ═══════════════════════════════════════════════════════════ -->
    <record id="action_notification_rules" model="ir.actions.act_window">
        <field name="name">Notification Rules</field>
        <field name="res_model">ons.notification.rule</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
