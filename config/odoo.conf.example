[options]
; ─── Database ────────────────────────────────────────────────────────────────
db_host = odoo-db
db_port = 5432
db_user = odoo
db_password = CHANGE_ME
db_name = onservice_prod_db
dbfilter = ^onservice_prod_db$
list_db = False

; ─── Paths ───────────────────────────────────────────────────────────────────
addons_path = /mnt/extra-addons,/usr/lib/python3/dist-packages/odoo/addons
data_dir = /var/lib/odoo

; ─── Security ────────────────────────────────────────────────────────────────
admin_passwd = CHANGE_ME

; ─── Network / Performance ───────────────────────────────────────────────────
workers = 4
limit_memory_hard = 2684354560
limit_memory_soft = 2147483648
limit_time_cpu = 600
limit_time_real = 1200
limit_time_real_cron = 3600
max_cron_threads = 1

; ─── Proxy / Reverse Proxy ───────────────────────────────────────────────────
proxy_mode = True

; ─── Logging ─────────────────────────────────────────────────────────────────
log_level = info
log_handler = :INFO

; ─── Server-wide modules ─────────────────────────────────────────────────────
server_wide_modules = base,web
